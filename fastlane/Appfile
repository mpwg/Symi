require "dotenv"

Dotenv.load(File.expand_path("../.env", __dir__))

def require_env!(key)
  ENV.fetch(key) do
    raise KeyError, "Fehlende Umgebungsvariable #{key}. Lege sie lokal in .env an oder setze sie in CI als Secret."
  end
end

app_identifier("eu.mpwg.MigraineTracker") # The bundle identifier of your app
apple_id(require_env!("FASTLANE_APPLE_ID")) # Apple Developer Portal username

itc_team_id(require_env!("FASTLANE_ITC_TEAM_ID")) # App Store Connect Team ID
team_id(require_env!("FASTLANE_TEAM_ID")) # Developer Portal Team ID

# For more information about the Appfile, see:
#     https://docs.fastlane.tools/advanced/#appfile
