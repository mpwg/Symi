      }
    },
    "%@ ist dein ruhiges Migräne Tagebuch. Du hältst fest, was passiert ist, und entscheidest selbst, welche zusätzlichen Daten du einbeziehst." : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%1$@ is your calm migraine diary. You record what happened and decide which additional data you want to include."
          }
        }
      }
    },
    "%@ mm Niederschlag" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%1$@ mm precipitation"
          }
        }
      }
    },
    "%@ speichert deine Angaben ausschließlich lokal auf diesem Gerät. Die App hilft dir, Migräne, Kopfschmerzen und andere Schmerzereignisse für dich und für Arztgespräche strukturiert festzuhalten." : {
      "extractionState" : "stale",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%1$@ stores your information only locally on this device. The app helps you keep a structured record of migraines, headaches and other pain events for yourself and for doctor appointments."
          }
        }
      }
    },
    "%@ wird aus SwiftData entfernt." : {
      "localizations" : {
